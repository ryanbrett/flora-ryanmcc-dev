rules_version = '2';
service firebase.storage {
  match /b/{bucket}/o {
    match /plants/{allPaths=**} {
      // Public Read Access
      allow read: if true;
      
      // Authenticated Write Access
      allow write: if request.auth != null
                   && request.resource.size < 5 * 1024 * 1024 // 5MB limit
                   && request.resource.contentType.matches('image/.*');
    }
  }
}
